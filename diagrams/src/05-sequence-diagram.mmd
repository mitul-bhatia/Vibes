sequenceDiagram
  autonumber
  participant U as User
  participant FE as Frontend
  participant API as Backend API
  participant SVC as Matching Service
  participant DB as Database

  U->>FE: Submit swipe action
  FE->>API: POST /discovery/swipe
  API->>SVC: evaluateSwipe(userId, targetId, direction)
  SVC->>DB: saveSwipe()
  DB-->>SVC: swipeSaved
  SVC->>DB: checkMutualLike()
  DB-->>SVC: mutualLike

  alt mutualLike is true
    SVC->>DB: createMatchAndConversation()
    DB-->>SVC: matchCreated
    SVC-->>API: swipeResult(matched=true)
    API-->>FE: 200 match payload
    FE-->>U: show match modal
  else mutualLike is false
    SVC-->>API: swipeResult(matched=false)
    API-->>FE: 200 continue payload
    FE-->>U: keep browsing cards
  end
